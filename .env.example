# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=inventory_db

# Backend
DATABASE_URL=postgresql+asyncpg://walle_user:yourpassword@localhost:5432/inventory_db
SECRET_KEY=your_secret_key_here
DEBUG=True
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# Frontend (Vite build arg — set to your deployed backend URL for production)
VITE_API_URL=http://localhost:8000
